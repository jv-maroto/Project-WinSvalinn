{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinSvalinn",
  "version": "1.0.2",
  "identifier": "com.jvmaroto.winsvalinn",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev || npm run dev",
    "beforeBuildCommand": "npm --prefix frontend run build || npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WinSvalinn",
        "width": 1285,
        "height": 912,
        "minWidth": 860,
        "minHeight": 540,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "backgroundColor": "#05070c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "externalBin": ["binaries/winsvalinn-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "wix": { "language": ["es-ES", "en-US"] },
      "nsis": {
        "languages": ["Spanish", "English"],
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/thanks.bmp"
      }
    }
  },
  "plugins": {}
}
